{
  "name": "forgespec",
  "version": "1.0.3",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "description": "Multi-agent SDD plugin — Zod contract validation, task board with dependency management, file reservation, and shared SQLite database. Compatible with OpenCode, Claude, Gemini, and Codex.",
  "keywords": [
    "sdd",
    "spec-driven-development",
    "multi-agent",
    "task-board",
    "contracts",
    "zod",
    "opencode",
    "claude",
    "gemini",
    "codex",
    "ai-agents"
  ],
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.3.5"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "author": "lleontor705",
  "repository": {
    "type": "git",
    "url": "https://github.com/lleontor705/forgespec.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.26"
  },
  "devDependencies": {
    "bun-types": "^1.2.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "typecheck": "bun x tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  }
}